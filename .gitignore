# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
build/
dist/
.eggs/

# uv / virtualenvs
.venv/
venv/

# Test / tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# OS / editor
.DS_Store
*.swp

# Builtin skills: SKILL.md + scripts/ are committed, but fetched host binaries are
# not — they land in each skill's bin/ (or dist/) via scripts/fetch.sh. Ignore the
# fetched payloads; keep the bin/.gitkeep placeholder so the empty dir is tracked.
skills/*/bin/*
!skills/*/bin/.gitkeep
skills/*/dist/

# Local ordna task board (internal planning — kept local, not published to this public repo)
/tasks/
/.ordna/

# Full-res logo master — keep local; only the resized rekit-factory-logo.png is published
/rekit-factory-logo-source.png
